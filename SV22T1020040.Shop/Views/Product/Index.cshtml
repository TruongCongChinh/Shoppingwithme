@model SV22T1020040.Shop.Models.ProductSearchViewModel
@{
    ViewData["Title"] = "Sản phẩm - ChinhShopping";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">

<style>
    :root {
        --primary-grad: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --primary-color: #667eea;
        --secondary-color: #764ba2;
    }

    body {
        background-color: #f8f9fa;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .modern-card {
        border-radius: 24px;
        border: none;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.04);
        overflow: hidden;
        background: #fff;
    }

    .filter-header {
        background: var(--primary-grad);
        color: white;
        padding: 20px 25px;
        border: none;
    }

    .form-control, .form-select {
        border-radius: 12px;
        padding: 10px 15px;
        border: 1px solid #e9ecef;
        transition: all 0.3s;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
        }

    .btn-search-modern {
        background: var(--primary-grad);
        color: white;
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.3s;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

        .btn-search-modern:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(102, 126, 234, 0.3);
            color: white;
            opacity: 0.9;
        }

    .filter-label {
        font-size: 0.75rem;
        font-weight: 700;
        color: #adb5bd;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
        display: block;
    }

    .spinner-modern {
        color: var(--primary-color);
        width: 3rem;
        height: 3rem;
    }

    #searchResult {
        transition: all 0.3s ease-in-out;
    }
</style>

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4 animate__animated animate__fadeIn">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Trang chủ</a></li>
            <li class="breadcrumb-item active fw-bold" aria-current="page" style="color: var(--primary-color)">Cửa hàng</li>
        </ol>
    </nav>

    <div class="card modern-card mb-5 animate__animated animate__fadeInDown">
        <div class="card-header filter-header d-flex align-items-center">
            <i class="fa-solid fa-sliders me-3 fs-4"></i>
            <h5 class="mb-0 fw-bold">Bộ lọc sản phẩm</h5>
        </div>
        <div class="card-body p-4 p-lg-5">
            <form id="formSearch" action="@Url.Action("SearchProduct", "Product")" method="get" data-target="searchResult">
                <input type="hidden" name="PageSize" value="@Model.SearchInput.PageSize" />
                <input type="hidden" name="SortOrder" id="hiddenSortOrder" value="@Model.SearchInput.SortOrder" />

                <div class="row g-4 align-items-end">
                    <div class="col-lg-3 col-md-6">
                        <label class="filter-label">Danh mục</label>
                        <select name="CategoryID" class="form-select shadow-sm" onchange="paginationSearch(null, document.getElementById('formSearch'), 1)">
                            <option value="0">Tất cả danh mục</option>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.CategoryID" selected="@(Model.SearchInput.CategoryID == cat.CategoryID)">
                                    @cat.CategoryName
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-lg-4 col-md-6">
                        <label class="filter-label">Khoảng giá (VNĐ)</label>
                        <div class="d-flex align-items-center gap-2">
                            <input type="number" name="MinPrice" class="form-control shadow-sm" placeholder="Từ" value="@Model.SearchInput.MinPrice" />
                            <span class="text-muted">—</span>
                            <input type="number" name="MaxPrice" class="form-control shadow-sm" placeholder="Đến" value="@Model.SearchInput.MaxPrice" />
                        </div>
                    </div>

                    <div class="col-lg-3 col-md-8">
                        <label class="filter-label">Tìm kiếm tên</label>
                        <div class="input-group shadow-sm rounded-3 overflow-hidden">
                            <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                            <input type="text" name="SearchValue" class="form-control border-start-0" value="@Model.SearchInput.SearchValue" placeholder="Nhập tên sản phẩm..." />
                        </div>
                    </div>

                    <div class="col-lg-2 col-md-4">
                        <button type="submit" class="btn btn-search-modern w-100 py-2 shadow-sm" style="height: 48px;">
                            Tìm kiếm
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div id="searchResult" class="animate__animated animate__fadeIn">
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function paginationSearch(e, form, page) {
            if (e) e.preventDefault();

            var actualForm = form || document.getElementById("formSearch");
            var url = $(actualForm).attr('action');
            var targetId = $(actualForm).data('target');
            var targetDiv = $('#' + targetId);

            var searchData = $(actualForm).serializeArray();
            searchData.push({ name: "Page", value: page });

            targetDiv.css({ 'opacity': '0.5', 'pointer-events': 'none' });
            if (targetDiv.html().trim() === "") {
                targetDiv.html('<div class="text-center py-5"><div class="spinner-border spinner-modern" role="status"></div><p class="mt-3 text-muted fw-bold">Đang tìm kiếm sản phẩm...</p></div>');
            }

            $.ajax({
                url: url,
                type: 'GET',
                data: searchData,
                success: function (result) {
                    targetDiv.css({ 'opacity': '1', 'pointer-events': 'auto' });
                    targetDiv.html(result);
                    if (page > 1) {
                        $('html, body').animate({ scrollTop: targetDiv.offset().top - 150 }, 300);
                    }
                },
                error: function () {
                    targetDiv.css({ 'opacity': '1', 'pointer-events': 'auto' });
                    targetDiv.html('<div class="alert alert-danger rounded-4 shadow-sm"><i class="fa-solid fa-triangle-exclamation me-2"></i> Không thể kết nối đến máy chủ.</div>');
                }
            });
        }

        $(document).ready(function () {
            var searchForm = document.getElementById("formSearch");

            $(searchForm).on('submit', function (e) {
                paginationSearch(e, this, 1);
            });

            paginationSearch(null, searchForm, @Model.SearchInput.Page);

            $(document).on('click', '.add-to-cart', function(e) {
                e.preventDefault();
                e.stopPropagation();

                var btn = $(this);
                var productId = btn.data('product-id');
                var originalHtml = btn.html();

                btn.html('<span class="spinner-border spinner-border-sm"></span>').prop('disabled', true);

                $.post('@Url.Action("AddToCart", "Cart")', { productId: productId, quantity: 1 })
                    .done(function(res) {
                        if (res.success) {
                            const Toast = Swal.mixin({
                                toast: true,
                                position: 'bottom-end',
                                showConfirmButton: false,
                                timer: 2000,
                                timerProgressBar: true
                            });

                            Toast.fire({
                                icon: 'success',
                                title: 'Đã thêm vào giỏ hàng!'
                            });

                            $('#cartCount').text(res.cartCount).addClass('animate__animated animate__rubberBand');
                            setTimeout(() => $('#cartCount').removeClass('animate__animated animate__rubberBand'), 1000);

                            btn.html('<i class="fa-solid fa-check"></i>').addClass('btn-success').removeClass('btn-primary');
                            setTimeout(() => {
                                btn.html(originalHtml).removeClass('btn-success').addClass('btn-primary').prop('disabled', false);
                            }, 2000);
                        }
                    })
                    .fail(function() {
                        alert('Lỗi kết nối!');
                        btn.html(originalHtml).prop('disabled', false);
                    });
            });
        });
    </script>
}