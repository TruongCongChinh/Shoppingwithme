@model SV22T1020040.Models.Catalog.Product
@{
    ViewData["Title"] = Model.ProductName;
    var attributes = ViewBag.Attributes as List<SV22T1020040.Models.Catalog.ProductAttribute>;
    var photos = ViewBag.Photos as List<SV22T1020040.Models.Catalog.ProductPhoto>;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    :root {
        --primary-grad: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --accent-color: #ff4757;
    }

    body {
        background-color: #fcfcfd;
    }

    .detail-card {
        border: none;
        border-radius: 30px;
        background: #fff;
        box-shadow: 0 10px 40px rgba(0,0,0,0.04);
        overflow: hidden;
        margin-bottom: 50px;
    }

    .image-section {
        background: #f8f9fa;
        padding: 40px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
    }

    .main-img-wrapper {
        width: 100%;
        height: 400px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fff;
        border-radius: 24px;
        padding: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.02);
    }

    #mainImage {
        max-height: 100%;
        max-width: 100%;
        object-fit: contain;
        transition: transform 0.5s ease;
    }

    .thumb-item {
        border-radius: 12px;
        border: 2px solid transparent;
        transition: 0.3s;
        padding: 5px;
        background: white;
    }

        .thumb-item:hover, .thumb-item.active {
            border-color: #667eea;
            transform: translateY(-3px);
        }

    .info-section {
        padding: 40px;
    }

    .product-title {
        font-weight: 800;
        color: #1a1a1a;
        font-size: 2.2rem;
        margin-bottom: 15px;
    }

    .price-tag {
        font-size: 2.5rem;
        font-weight: 800;
        background: var(--primary-grad);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .specs-table {
        border-radius: 15px;
        overflow: hidden;
        border: 1px solid #f1f3f5;
    }

        .specs-table th {
            background-color: #f8f9fa;
            color: #6c757d;
            font-weight: 600;
            width: 35%;
        }

    .qty-selector {
        background: #f1f3f5;
        border-radius: 50px;
        padding: 5px;
        display: inline-flex;
        align-items: center;
    }

    .qty-btn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: none;
        background: white;
        color: #764ba2;
        font-weight: bold;
        transition: 0.3s;
    }

        .qty-btn:hover {
            background: var(--primary-grad);
            color: white;
        }

    .qty-input {
        background: transparent;
        border: none;
        width: 60px;
        text-align: center;
        font-weight: 700;
        font-size: 1.1rem;
    }

    .btn-add-cart-lg {
        background: var(--primary-grad);
        color: white;
        border: none;
        padding: 15px 40px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 1.1rem;
        transition: 0.4s;
        box-shadow: 0 10px 25px rgba(102, 126, 234, 0.3);
    }

        .btn-add-cart-lg:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(102, 126, 234, 0.5);
            color: white;
        }
</style>

<div class="container mt-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="/Product" class="text-decoration-none">Sản phẩm</a></li>
            <li class="breadcrumb-item active">@Model.ProductName</li>
        </ol>
    </nav>

    <div class="detail-card">
        <div class="row g-0">
            <div class="col-lg-6">
                <div class="image-section">
                    <div class="main-img-wrapper animate__animated animate__fadeIn">
                        <img id="mainImage" src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                             alt="@Model.ProductName">
                    </div>

                    @if (photos != null && photos.Any())
                    {
                        <div class="d-flex gap-3 mt-4 overflow-auto pb-2 w-100 justify-content-center">
                            <img src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                                 class="thumb-item active" style="width:70px; height:70px; object-fit:cover; cursor:pointer"
                                 onclick="changeImage(this, '/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)')" />

                            @foreach (var photo in photos.Where(p => !p.IsHidden))
                            {
                                <img src="~/images/products/@photo.Photo"
                                     class="thumb-item" style="width:70px; height:70px; object-fit:cover; cursor:pointer"
                                     onclick="changeImage(this, '/images/products/@photo.Photo')" />
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-6">
                <div class="info-section">
                    <div class="mb-2">
                        <span class="badge rounded-pill px-3 py-2 bg-primary bg-opacity-10 text-primary fw-bold">@Model.CategoryName</span>
                        <span class="badge rounded-pill px-3 py-2 bg-info bg-opacity-10 text-info fw-bold ms-1">@Model.SupplierName</span>
                    </div>

                    <h1 class="product-title">@Model.ProductName</h1>

                    <div class="d-flex align-items-center mb-4">
                        <div class="price-tag me-3">@Model.Price.ToString("#,##0") đ</div>
                        <div class="text-muted fs-5">/ @Model.Unit</div>
                    </div>

                    <div class="mb-4">
                        <h6 class="fw-bold text-dark"><i class="fa-solid fa-align-left me-2"></i>Mô tả sản phẩm</h6>
                        <p class="text-muted" style="line-height: 1.6;">@Model.ProductDescription</p>
                    </div>

                    @if (attributes != null && attributes.Any())
                    {
                        <div class="mb-4">
                            <h6 class="fw-bold text-dark"><i class="fa-solid fa-gear me-2"></i>Thông số kỹ thuật</h6>
                            <table class="table table-sm specs-table mt-2">
                                @foreach (var attr in attributes.OrderBy(a => a.DisplayOrder))
                                {
                                    <tr>
                                        <th class="ps-3">@attr.AttributeName</th>
                                        <td class="ps-3">@attr.AttributeValue</td>
                                    </tr>
                                }
                            </table>
                        </div>
                    }

                    <div class="row g-3 align-items-center mt-5">
                        <div class="col-auto">
                            <div class="qty-selector">
                                <button class="qty-btn" type="button" onclick="decreaseQty()"><i class="fa-solid fa-minus"></i></button>
                                <input type="number" id="quantity" class="qty-input" value="1" min="1" readonly>
                                <button class="qty-btn" type="button" onclick="increaseQty()"><i class="fa-solid fa-plus"></i></button>
                            </div>
                        </div>
                        <div class="col">
                            <button class="btn btn-add-cart-lg w-100" onclick="addToCart()">
                                <i class="fa-solid fa-cart-plus me-2"></i> THÊM VÀO GIỎ HÀNG
                            </button>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-4 text-muted small">
                        <span><i class="fa-solid fa-truck-fast text-primary me-1"></i> Giao hàng toàn quốc</span>
                        <span><i class="fa-solid fa-shield-check text-success me-1"></i> Bảo hành chính hãng</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function changeImage(el, src) {
            $('#mainImage').fadeOut(200, function() {
                $(this).attr('src', src).fadeIn(200);
            });
            $('.thumb-item').removeClass('active');
            $(el).addClass('active');
        }

        function decreaseQty() {
            var qty = parseInt($('#quantity').val());
            if (qty > 1) $('#quantity').val(qty - 1);
        }

        function increaseQty() {
            var qty = parseInt($('#quantity').val());
            $('#quantity').val(qty + 1);
        }

        function addToCart() {
            var productId = @Model.ProductID;
            var quantity = $('#quantity').val();
            var btn = $('.btn-add-cart-lg');

            btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span> Đang xử lý...');

            $.post('@Url.Action("AddToCart", "Cart")', { productId: productId, quantity: quantity })
                .done(function(response) {
                    if (response.success) {
                        $('#cartCount').text(response.cartCount).addClass('animate__animated animate__bounceIn');
                        setTimeout(() => $('#cartCount').removeClass('animate__animated animate__bounceIn'), 1000);

                        Swal.fire({
                            icon: 'success',
                            title: 'Thành công!',
                            text: 'Đã thêm ' + quantity + ' sản phẩm vào giỏ hàng',
                            showConfirmButton: false,
                            timer: 2000,
                            toast: true,
                            position: 'bottom-end'
                        });
                    } else {
                        Swal.fire({ icon: 'error', title: 'Lỗi', text: response.message });
                    }
                })
                .fail(function() {
                    Swal.fire({ icon: 'error', title: 'Lỗi', text: 'Có lỗi xảy ra khi kết nối máy chủ' });
                })
                .always(function() {
                    btn.prop('disabled', false).html('<i class="fa-solid fa-cart-plus me-2"></i> THÊM VÀO GIỎ HÀNG');
                });
        }
    </script>
}