@using System.Security.Claims
@using SV22T1020040.Shop
@using SV22T1020040.Shop.Extensions
@using SV22T1020040.Shop.Models
@{
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var displayName = isAuthenticated ? (User.FindFirst("DisplayName")?.Value ?? User.FindFirst(ClaimTypes.Name)?.Value ?? "Người dùng") : "";
    var email = isAuthenticated ? (User.FindFirst(ClaimTypes.Email)?.Value ?? "") : "";
    var firstChar = !string.IsNullOrEmpty(displayName) ? displayName.Substring(0, 1).ToUpper() : "U";
}

<nav class="custom-header navbar navbar-expand-lg">
    <div class="container-fluid px-4">
        <div class="d-flex align-items-center gap-3">
            <a href="~/" class="shop-logo text-decoration-none">
                <span>Shopping</span>
            </a>
            <ul class="navbar-nav d-none d-md-flex flex-row gap-3 ms-3">
                <li class="nav-item">
                    <a href="~/" class="nav-link header-link">Trang chủ</a>
                </li>
                <li class="nav-item">
                    <a href="~/Product" class="nav-link header-link">Sản phẩm</a>
                </li>
                <li class="nav-item">
                    <a href="~/Cart" class="nav-link header-link">Giỏ hàng</a>
                </li>
            </ul>
        </div>

        <ul class="navbar-nav ms-auto align-items-center gap-2">
            <!-- Cart Button -->
            <li class="nav-item">
                <a href="~/Cart" class="cart-button text-decoration-none position-relative">
                    <i class="fa-solid fa-cart-shopping"></i>
                    <span>Giỏ hàng</span>
                    <span id="cartCount" class="badge bg-danger rounded-pill ms-1" style="font-size: 0.7rem;">0</span>
                </a>
            </li>

            @if (isAuthenticated)
            {
                <li class="nav-item dropdown user-menu">
                    <a href="#" class="nav-link user-trigger d-flex align-items-center gap-2" data-bs-toggle="dropdown" aria-expanded="false">
                        <div class="user-avatar rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width: 35px; height: 35px; font-size: 16px; font-weight: 600;">
                            <span>@firstChar</span>
                        </div>
                        <span class="d-none d-md-inline user-name">@displayName</span>
                        <i class="fa-solid fa-chevron-down small text-muted"></i>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end user-dropdown shadow border-0 mt-2">
                        <li class="user-dropdown-header text-center px-3 py-3 bg-primary text-white rounded-top">
                            <div class="rounded-circle bg-white text-primary d-flex align-items-center justify-content-center mx-auto mb-2" style="width: 60px; height: 60px; font-size: 24px; font-weight: 700;">
                                <span>@firstChar</span>
                            </div>
                            <h6 class="mb-0 fw-semibold text-white">@displayName</h6>
                            <small class="text-white-50">@email</small>
                        </li>
                        <li><hr class="dropdown-divider m-0"></li>
                        <li>
                            <a class="dropdown-item py-2" href="~/ShopAccount/Profile">
                                <i class="fa-regular fa-id-badge me-2"></i> Thông tin cá nhân
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item py-2" href="~/ShopAccount/ChangePassword">
                                <i class="fa-solid fa-unlock-keyhole me-2"></i> Đổi mật khẩu
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item py-2" href="~/Order">
                                <i class="fa-solid fa-receipt me-2"></i> Đơn hàng của tôi
                            </a>
                        </li>
                        <li><hr class="dropdown-divider m-0"></li>
                        <li>
                            <a class="dropdown-item py-2 text-danger" href="~/ShopAccount/Logout">
                                <i class="fa-solid fa-arrow-right-from-bracket me-2"></i> Đăng xuất
                            </a>
                        </li>
                    </ul>
                </li>
            }
            else
            {
                <li class="nav-item">
                    <a href="~/ShopAccount/Login" class="btn-login text-decoration-none px-3 py-1 rounded-pill">
                        <i class="fa-solid fa-right-to-bracket me-1"></i> Đăng nhập
                    </a>
                </li>
                <li class="nav-item">
                    <a href="~/ShopAccount/Register" class="btn-register text-decoration-none px-3 py-1 rounded-pill bg-primary text-white">
                        <i class="fa-solid fa-user-plus me-1"></i> Đăng ký
                    </a>
                </li>
            }
        </ul>
    </div>
</nav>

<style>
    .user-dropdown {
        min-width: 260px;
        border-radius: 12px;
        overflow: hidden;
    }

    .user-dropdown-header {
        background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
    }

    .user-trigger {
        border-radius: 40px;
        padding: 6px 12px;
        transition: all 0.3s ease;
    }

        .user-trigger:hover {
            background-color: rgba(0,0,0,0.05);
        }

    .user-avatar {
        transition: transform 0.2s ease;
    }

    .user-trigger:hover .user-avatar {
        transform: scale(1.05);
    }

    .btn-login {
        color: #4b5563;
        transition: all 0.3s ease;
    }

        .btn-login:hover {
            color: #2563eb;
            background-color: rgba(37, 99, 235, 0.1);
        }

    .btn-register {
        transition: all 0.3s ease;
    }

        .btn-register:hover {
            background-color: #1d4ed8;
            transform: translateY(-1px);
        }

    .cart-button {
        color: #4b5563;
        padding: 6px 12px;
        border-radius: 40px;
        transition: all 0.3s ease;
    }

        .cart-button:hover {
            color: #2563eb;
            background-color: rgba(37, 99, 235, 0.1);
        }

    .dropdown-item {
        transition: all 0.2s ease;
    }

        .dropdown-item:hover {
            background-color: #f3f4f6;
            padding-left: 20px;
        }
</style>