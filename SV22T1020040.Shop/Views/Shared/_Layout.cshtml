<!doctype html>
<html lang="en">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title>ChinhShopping</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="~/css/shop.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-light">
    @await Html.PartialAsync("_Header")

    <main class="container my-4">
        @RenderBody()
    </main>

    @await Html.PartialAsync("_Footer")

    <button id="scrollToTop" onclick="window.scrollTo({top:0,behavior:'smooth'})"
            style="position:fixed;bottom:30px;right:30px;width:50px;height:50px;border-radius:50%;background:#2563eb;color:white;border:none;cursor:pointer;display:none;box-shadow:0 4px 6px -1px rgb(0 0 0 / 0.1);transition:all 0.3s ease;z-index:999">
        <i class="bi bi-arrow-up"></i>
    </button>

    <div class="modal fade" id="dialogModal" tabindex="-1" aria-hidden="true" style="display:none;">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/shop.js"></script>

    <script>
        window.addEventListener('scroll', function() {
            var btn = document.getElementById('scrollToTop');
            if (window.scrollY > 300) {
                btn.style.display = 'block';
            } else {
                btn.style.display = 'none';
            }
        });

        function updateCartCount() {
            $.get('/Cart/GetCartCount', function(data) {
                $('#cartCount').text(data.count);
            });
        }

        $(document).ready(function() {
            updateCartCount();
        });

        $(document).click(function(event) {
            if (!$(event.target).closest('.user-menu').length) {
                $('.user-menu .dropdown-menu').removeClass('show');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>