@using SV22T1020040.Models.Catalog
@using SV22T1020040.Shop
@using SV22T1020040.Shop.Extensions
@using SV22T1020040.Shop.Models
@{
    ViewData["Title"] = "Trang chủ - ChinhShopping";
    var featuredProducts = ViewBag.FeaturedProducts as List<Product> ?? new List<Product>();
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">

<style>
    :root {
        --primary-grad: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --accent-color: #ff4757;
        --glass-bg: rgba(255, 255, 255, 0.8);
        --text-dark: #1a1a1a;
    }

    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background-color: #fcfcfd;
        color: var(--text-dark);
    }

    .hero-section {
        background: linear-gradient(-45deg, #667eea, #764ba2, #4facfe, #00f2fe);
        background-size: 400% 400%;
        animation: gradientMove 15s ease infinite;
        padding: 120px 0;
        border-radius: 0 0 60px 60px;
        position: relative;
        overflow: hidden;
    }

    @@keyframes gradientMove {
        0% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }
    }

    .category-card {
        border: 1px solid #f1f3f5;
        border-radius: 22px;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        background: #fff;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

        .category-card:hover {
            border-color: transparent;
            background: var(--primary-grad);
            color: white !important;
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(102, 126, 234, 0.2);
        }

        .category-card i {
            transition: all 0.4s ease;
            color: #667eea;
        }

        .category-card:hover i {
            color: white !important;
            transform: scale(1.2);
        }

    .slider-container {
        display: flex;
        gap: 24px;
        overflow-x: auto;
        padding: 20px 10px 40px 10px;
        scroll-behavior: smooth;
        -webkit-overflow-scrolling: touch;
    }

        .slider-container::-webkit-scrollbar {
            height: 8px;
        }

        .slider-container::-webkit-scrollbar-track {
            background: #f1f3f5;
            border-radius: 10px;
        }

        .slider-container::-webkit-scrollbar-thumb {
            background: #cbd5e0;
            border-radius: 10px;
            transition: 0.3s;
        }

            .slider-container::-webkit-scrollbar-thumb:hover {
                background: #764ba2;
            }

    .slider-item {
        flex: 0 0 auto;
        width: 300px;
    }

    .product-card {
        border: none;
        border-radius: 24px;
        transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
        background: #fff;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .product-card:hover {
            transform: translateY(-12px);
            box-shadow: 0 30px 60px rgba(102, 126, 234, 0.12);
        }

    .product-img-wrapper {
        border-radius: 20px;
        margin: 15px;
        overflow: hidden;
        height: 200px;
        background: #f8f9fa;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .product-img {
        max-width: 85%;
        max-height: 85%;
        object-fit: contain;
        transition: transform 0.6s ease;
    }

    .product-card:hover .product-img {
        transform: scale(1.1);
    }

    .btn-add-cart-modern {
        background: var(--primary-grad);
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 50px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.2);
    }

        .btn-add-cart-modern:hover {
            transform: scale(1.05);
            color: white;
        }

    .benefit-item {
        background: #fff;
        border-radius: 24px;
        padding: 40px 20px;
        border: 1px solid #f1f3f5;
        transition: 0.4s;
    }

        .benefit-item:hover {
            border-color: #667eea;
            transform: translateY(-5px);
        }
</style>

<div class="hero-section text-white text-center">
    <div class="container animate__animated animate__fadeIn">
        <h1 class="fw-bold display-3 mb-3">Xin chào bạn đã đến với ChinhShopping</h1>
        <p class="lead mb-5 opacity-75 fs-4">Nâng tầm - Trải nghiệm mua sắm công nghệ mới</p>
        <a asp-controller="Product" asp-action="Index" class="btn btn-light btn-lg px-5 py-3 rounded-pill fw-bold text-primary shadow-lg">
            <i class="fa-solid fa-rocket me-2"></i> Khám phá ngay
        </a>
    </div>
</div>

<div class="container mt-5 pt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold m-0"><i class="fa-solid fa-grip text-primary me-2"></i> Danh mục sản phẩm</h3>
        <a href="@Url.Action("Index", "Product")" class="text-primary text-decoration-none fw-bold">Xem tất cả <i class="fa-solid fa-chevron-right ms-1"></i></a>
    </div>
    <div class="row g-4">
        @foreach (var cat in categories.Take(6))
        {
            <div class="col-lg-2 col-md-4 col-6">
                <a href="@Url.Action("Index", "Product", new { categoryId = cat.CategoryID })" class="text-decoration-none text-dark h-100 d-block">
                    <div class="category-card p-4 shadow-sm">
                        <div class="mb-3">
                            @{
                                string iconClass = "fa-box-open";
                                string name = cat.CategoryName.ToUpper();
                                if (name.Contains("NỘI THẤT")) iconClass = "fa-couch";
                                else if (name.Contains("ĐIỆN TỬ")) iconClass = "fa-microchip";
                                else if (name.Contains("ĐỒ CHƠI")) iconClass = "fa-gamepad";
                                else if (name.Contains("GIA DỤNG")) iconClass = "fa-kitchen-set";
                                else if (name.Contains("MAY MẶC")) iconClass = "fa-shirt";
                                else if (name.Contains("MẸ VÀ EM BÉ")) iconClass = "fa-baby-carriage";
                            }
                            <i class="fa-solid @iconClass fs-1"></i>
                        </div>
                        <span class="fw-bold small text-uppercase text-center">@cat.CategoryName</span>
                    </div>
                </a>
            </div>
        }
    </div>
</div>

<div class="container mt-5 pt-5">
    <div class="d-flex align-items-center mb-4">
        <h3 class="fw-bold m-0"><i class="fa-solid fa-fire text-danger me-2"></i> Sản phẩm nổi bật</h3>
        <span class="ms-3 badge rounded-pill bg-danger animate__animated animate__pulse animate__infinite">HOT</span>
    </div>

    <div class="slider-container">
        @foreach (var product in featuredProducts)
        {
            <div class="slider-item">
                <div class="card product-card">
                    <div class="product-img-wrapper">
                        <img src="~/images/products/@(string.IsNullOrEmpty(product.Photo) ? "nophoto.png" : product.Photo)"
                             class="product-img" alt="@product.ProductName">
                    </div>
                    <div class="card-body p-4 d-flex flex-column">
                        <h6 class="fw-bold text-truncate mb-2">@product.ProductName</h6>
                        <p class="text-muted small mb-3" style="font-size: 0.8rem; height: 3em; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                            @product.ProductDescription
                        </p>
                        <div class="mt-auto d-flex justify-content-between align-items-center" style="position: relative; z-index: 5;">
                            <span class="text-primary fw-bold fs-5">@product.Price.ToString("#,##0") đ</span>
                            <button class="add-to-cart btn-add-cart-modern" data-product-id="@product.ProductID">
                                <i class="fa-solid fa-cart-shopping"></i>
                                <span>Mua</span>
                            </button>
                        </div>
                    </div>
                    <a href="@Url.Action("Detail", "Product", new { id = product.ProductID })" class="stretched-link"></a>
                </div>
            </div>
        }
    </div>
</div>

<div class="container my-5 pt-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="benefit-item text-center">
                <i class="fa-solid fa-truck-fast fs-1 text-primary mb-3"></i>
                <h5 class="fw-bold">Giao hàng miễn phí</h5>
                <p class="text-muted small mb-0">Cho hóa đơn từ 333k trở lên</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="benefit-item text-center">
                <i class="fa-solid fa-rotate-left fs-1 text-success mb-3"></i>
                <h5 class="fw-bold">Đổi trả 14 ngày</h5>
                <p class="text-muted small mb-0">Đổi mới sản phẩm nếu có lỗi kỹ thuật</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="benefit-item text-center">
                <i class="fa-solid fa-user-shield fs-1 text-warning mb-3"></i>
                <h5 class="fw-bold">Thanh toán bảo mật</h5>
                <p class="text-muted small mb-0">Đa dạng hình thức thanh toán an toàn và bảo mật cao</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function() {
            $('.add-to-cart').on('click', function(e) {
                e.preventDefault();
                e.stopPropagation();

                let btn = $(this);
                let productId = btn.data('product-id');
                let originalContent = btn.html();

                btn.html('<span class="spinner-border spinner-border-sm"></span>').prop('disabled', true);

                $.post('@Url.Action("AddToCart", "Cart")', { productId: productId, quantity: 1 })
                    .done(function(res) {
                        if (res.success) {
                            const Toast = Swal.mixin({
                                toast: true,
                                position: 'bottom-end',
                                showConfirmButton: false,
                                timer: 2000,
                                timerProgressBar: true
                            });

                            Toast.fire({
                                icon: 'success',
                                title: 'Đã thêm vào giỏ hàng!'
                            });

                            $('#cartCount').text(res.cartCount).addClass('animate__animated animate__rubberBand');
                            setTimeout(() => $('#cartCount').removeClass('animate__animated animate__rubberBand'), 1000);

                            btn.html('<i class="fa-solid fa-check"></i>').addClass('btn-success');
                            setTimeout(() => {
                                btn.html(originalContent).removeClass('btn-success').prop('disabled', false);
                            }, 2000);
                        }
                    })
                    .fail(function() {
                        btn.html(originalContent).prop('disabled', false);
                    });
            });
        });
    </script>
}